# flai configuration

# Application environment: development, local, test, staging, production
APP_ENV=development

# Server Port
PORT=8080

# Database driver: sqlite, postgres, or mysql
DB_DRIVER=sqlite

# SQLite database path (used only when DB_DRIVER=sqlite)
DB_PATH=flai.db

# PostgreSQL/MySQL connection string (used when DB_DRIVER is postgres or mysql)
# DB_DSN=host=127.0.0.1 user=flai password=change-me dbname=flai port=5432 sslmode=disable
# DB_DSN=flai:change-me@tcp(127.0.0.1:3306)/flai?charset=utf8mb4&parseTime=True&loc=Local
# DATABASE_URL is also supported as a fallback for DB_DSN.
DB_DSN=

# PostgreSQL/MySQL connection pool settings (SQLite uses a fixed small pool)
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=10
DB_CONN_MAX_LIFETIME_SECONDS=3600

# JWT Secret for dashboard sessions
JWT_SECRET=your-secure-jwt-secret-here

# OIDC Configuration
OIDC_ISSUER=https://your-oidc-provider.com
OIDC_CLIENT_ID=your-client-id
OIDC_CLIENT_SECRET=your-client-secret
OIDC_REDIRECT_URL=http://localhost:8080/auth/callback

# Optional: users matching these OIDC subjects or emails become admins on login
BOOTSTRAP_ADMIN_OIDC_SUBS=
BOOTSTRAP_ADMIN_EMAILS=
